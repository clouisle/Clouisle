msgid "builtin_tool_artifact"
msgstr "Create Download Link"

msgid "builtin_tool_artifact_description"
msgstr "Collect existing files or directories from /workspace and return Markdown download links for the assistant's final answer. Use this after generating and verifying final user-facing files with bash commands such as `ls`, `find`, or `file`. This tool does not render download cards directly; after calling it, include the returned Markdown links in the final response body. Relative paths are interpreted from /workspace."

msgid "builtin_tool_bash"
msgstr "Run Command"

msgid "builtin_tool_bash_description"
msgstr "Execute a Bash command in the sandbox workspace. Use this for running scripts, installing packages, inspecting files, and invoking CLI tools. The sandbox workspace is exposed to you as /workspace; prefer paths under /workspace when calling this tool and set cwd to /workspace or a subdirectory. The cwd value is mapped to the current sandbox session directory on disk. When you write Python or Node scripts with the write tool, those scripts should use relative paths (e.g., 'output/report.docx') or derive paths from their working directory, not hardcode /workspace/... inside the script code. To install Python packages, run `python3 -m pip install <package>` or `pip install <package>`; pip commands are normalized to python3 -m pip. To run Python code, prefer writing a script with the write tool, then run `python3 /workspace/script.py`. Inline checks like `python3 -c \"print('ok')\"` are also allowed. For Node packages, use `npm install <package>` in the workspace, then run scripts with `node /workspace/script.js` or `npm run <script>`. If a module is missing, install it first instead of repeatedly retrying the same command."

msgid "builtin_tool_calculate"
msgstr "Calculate"

msgid "builtin_tool_calculate_description"
msgstr "Evaluate math expressions. Supports basic operators (+, -, *, /, //, %, **), math functions (sqrt, sin, cos, tan, log, exp, abs, round, min, max, floor, ceil), and constants (pi, e)."

msgid "builtin_tool_calculate_param_expression_description"
msgstr "Math expression, e.g. '2 + 3 * 4', 'sqrt(16)', 'sin(pi/2)'"

msgid "builtin_tool_fetch_webpage"
msgstr "Fetch Webpage"

msgid "builtin_tool_fetch_webpage_description"
msgstr "Fetch webpage content. Read the text content of a URL for deeper inspection of search results."

msgid "builtin_tool_fetch_webpage_param_url_description"
msgstr "Webpage URL to fetch"

msgid "builtin_tool_fetch_webpage_param_max_length_description"
msgstr "Max characters to return. Default 5000."

msgid "builtin_tool_format_datetime"
msgstr "Format DateTime"

msgid "builtin_tool_format_datetime_description"
msgstr "Format a datetime. Convert a timestamp to a formatted string."

msgid "builtin_tool_format_datetime_param_timestamp_description"
msgstr "Unix timestamp (seconds). If omitted, uses current time."

msgid "builtin_tool_format_datetime_param_format_string_description"
msgstr "Python strftime format string, e.g. '%Y-%m-%d %H:%M:%S'"

msgid "builtin_tool_format_datetime_param_timezone_name_description"
msgstr "Timezone name. Default is UTC."

