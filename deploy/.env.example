# =============================================================================
# Clouisle Docker Deployment Environment Variables
# Copy this file to .env and fill in the values before deploying.
# =============================================================================

# ---- Image Registry ----
# For ACR: registry.cn-hangzhou.aliyuncs.com/clouisle/clouisle
# Leave default for local builds
IMAGE_REGISTRY=clouisle
IMAGE_TAG=latest

# ---- General ----
PROJECT_NAME=Clouisle
SECRET_KEY=changethis-to-a-secure-random-secret-key   # IMPORTANT: generate a strong random key
TIMEZONE=Asia/Shanghai
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL ----
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                                     # IMPORTANT: set a strong password
POSTGRES_DB=clouisle

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                                        # IMPORTANT: set a strong password

# ---- Qdrant (Vector DB) ----
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                                        # IMPORTANT: set a strong key
QDRANT_COLLECTION_PREFIX=kb_dim
QDRANT_DISTANCE=Cosine

# ---- CORS ----
# JSON array of allowed origins (include your actual domain)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ---- External APIs (optional) ----
TAVILY_API_KEY=
