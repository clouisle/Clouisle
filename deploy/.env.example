# =============================================================================
# Clouisle Docker Deployment Environment Variables
# Copy this file to .env inside deploy/ before running docker compose.
# =============================================================================

# ---- Images ----
# For a registry, use a repository prefix such as:
# IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com/your-namespace/clouisle
IMAGE_REGISTRY=clouisle
IMAGE_TAG=latest

# ---- General ----
PROJECT_NAME=Clouisle
SECRET_KEY=changethis-to-a-secure-random-secret-key
TIMEZONE=Asia/Shanghai

# ---- URLs ----
# Internal API address used by containers. Put public domains in FRONTEND_URL/CORS.
API_BASE_URL=http://api:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Sandbox workers upload artifacts to this internal API address.
SANDBOX_ARTIFACT_UPLOAD_BASE_URL=http://api:8000
SANDBOX_ARTIFACT_UPLOAD_API_KEY=

# ---- PostgreSQL ----
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=clouisle
# DATABASE_URL=postgres://postgres:password@db:5432/clouisle

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Qdrant ----
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=kb_dim
QDRANT_DISTANCE=Cosine

# ---- Sandbox Runtime ----
SANDBOX_RUNTIME_ENABLED=true
SANDBOX_LEGACY_FALLBACK_ENABLED=true
SANDBOX_WORKER_CONCURRENCY=1
SANDBOX_WORKSPACE_ROOT=/tmp/clouisle-sandbox/jobs
SANDBOX_MAX_DISK_MB=8192
SANDBOX_SESSION_TTL_HOURS=24
SANDBOX_RESULT_TTL_SECONDS=86400
SANDBOX_ARTIFACT_MAX_FILE_SIZE_MB=10
SANDBOX_ARTIFACT_MAX_TOTAL_SIZE_MB=10

# ---- Frontend Build ----
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_VERSION=0.0.0-dev
NEXT_PUBLIC_BUILD_DATE=unknown

# ---- External APIs (optional) ----
TAVILY_API_KEY=
