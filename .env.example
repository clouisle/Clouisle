# =============================================================================
# Clouisle Local Development Environment Configuration
# Copy this file to .env at the project root and modify as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PROJECT_NAME=Clouisle
SECRET_KEY=changethis-to-a-secure-random-secret-key
TIMEZONE=Asia/Shanghai

# URLs
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Sandbox workers upload artifacts to this URL when set.
# For Docker Compose deployment, use http://api:8000 in deploy/.env.
SANDBOX_ARTIFACT_UPLOAD_BASE_URL=
SANDBOX_ARTIFACT_UPLOAD_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=clouisle
# DATABASE_URL=postgres://postgres:password@localhost:5432/clouisle

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=kb_dim
QDRANT_DISTANCE=Cosine

# -----------------------------------------------------------------------------
# Sandbox Runtime
# -----------------------------------------------------------------------------
SANDBOX_RUNTIME_ENABLED=true
SANDBOX_LEGACY_FALLBACK_ENABLED=true
SANDBOX_WORKER_CONCURRENCY=1
SANDBOX_WORKSPACE_ROOT=/tmp/clouisle-sandbox/jobs
SANDBOX_MAX_DISK_MB=8192
SANDBOX_SESSION_TTL_HOURS=24
SANDBOX_RESULT_TTL_SECONDS=86400
SANDBOX_ARTIFACT_MAX_FILE_SIZE_MB=10
SANDBOX_ARTIFACT_MAX_TOTAL_SIZE_MB=10

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_BUILD_DATE=unknown
BACKEND_INTERNAL_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# External APIs (Optional)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
