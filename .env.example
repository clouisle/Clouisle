# =============================================================================
# Clouisle Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PROJECT_NAME=Clouisle
SECRET_KEY=changethis-to-a-secure-random-secret-key
TIMEZONE=Asia/Shanghai

# URLs (adjust for your deployment)
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Optional: explicit backend base URL for sandbox artifact uploads.
# If unset, sandbox workers prefer API_BASE_URL. In containerized deployments,
# localhost/127.0.0.1 may be auto-resolved to an internal backend address.
# SANDBOX_ARTIFACT_UPLOAD_BASE_URL=http://backend:8000

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # IMPORTANT: Set a strong random password
POSTGRES_DB=clouisle
# Optional: override full DSN
# DATABASE_URL=postgres://postgres:password@localhost:5432/clouisle

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # IMPORTANT: Set a strong random password

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # IMPORTANT: Set a strong random API key
QDRANT_COLLECTION_PREFIX=kb_dim
QDRANT_DISTANCE=Cosine

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# External APIs (Optional)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Auto-populated at build time; override if needed
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_BUILD_DATE=2026-02-07
